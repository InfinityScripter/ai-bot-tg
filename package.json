{
  "name": "ai-bot-tg",
  "version": "1.0.0",
  "description": "Telegram news bot: collects RSS daily, rewrites via Claude, owner approves in Telegram, publishes to the blog.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "ts": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"{src,tests,evals}/**/*.ts\"",
    "lint:fix": "eslint --fix \"{src,tests,evals}/**/*.ts\"",
    "fm:check": "prettier --check \"{src,tests,evals}/**/*.ts\"",
    "fm:fix": "prettier --write \"{src,tests,evals}/**/*.ts\"",
    "fetch": "tsx src/cli/runCollection.ts",
    "backfill:channel": "tsx src/cli/backfillChannel.ts",
    "test:models": "tsx src/cli/testModels.ts",
    "eval": "tsx evals/runEval.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "better-sqlite3": "^11.8.0",
    "croner": "^9.0.0",
    "dotenv": "^16.4.0",
    "grammy": "^1.44.0",
    "rss-parser": "^3.13.0",
    "tsx": "^4.19.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^4.15.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.3",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
