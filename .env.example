# Telegram
TELEGRAM_BOT_TOKEN=          # from @BotFather
OWNER_TELEGRAM_ID=           # your numeric Telegram chat id (DM target + auth allowlist)

# Rewrite backend: anthropic (paid) | gemini | glm | deepseek | openrouter | mock (no LLM)
# glm/deepseek are Chinese, OpenAI-compatible, RU-reachable and cheap/free.
REWRITE_PROVIDER=glm

# Claude — required only when REWRITE_PROVIDER=anthropic
ANTHROPIC_API_KEY=
REWRITE_MODEL=claude-haiku-4-5
# 1 = skip Claude and copy the feed item verbatim (no-credit pipeline testing only).
# Keep 0 in any real environment — mock output is not a real rewrite.
REWRITE_MOCK=0
# Sampling temperature, 0–1 (valid for Anthropic AND the OpenAI-compat providers).
REWRITE_TEMPERATURE=0.6
# Max output tokens for the rewrite; 4096 fits a full structured post.
REWRITE_MAX_TOKENS=4096
# Hard per-call timeout (ms) for EVERY LLM request (rewrite/classify/digest/…).
# Without it a stalled provider hangs a call for the SDK's ~10-min default, and
# since collection classifies serially, /fetch looks frozen. A classify that
# times out fails open (keep). Default 30000.
LLM_TIMEOUT_MS=30000
# Max automatic retries per LLM call (Anthropic SDK). Default 1; the SDK's own
# default of 2 multiplies back-off on a degraded provider. 0 disables retries.
LLM_MAX_RETRIES=1

# Gemini — when REWRITE_PROVIDER=gemini. Key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# GLM (Zhipu Z.ai) — when REWRITE_PROVIDER=glm. glm-4.7-flash is FREE. Key: https://z.ai
GLM_API_KEY=
GLM_MODEL=glm-4.7-flash

# DeepSeek — when REWRITE_PROVIDER=deepseek. V4 Flash ~$0.14/$0.28 per 1M. Key: https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# OpenRouter — when REWRITE_PROVIDER=openrouter. One key proxies many models,
# so a single working endpoint sidesteps the per-provider geo blocks that cause
# "fetch failed". Key: https://openrouter.ai/keys
# Default deepseek-chat: cheap ($0.20/$0.80 за 1M ≈ $4/yr at 15/run), fits the
# $5 free-tier credit so it runs without topping up, and returns clean text.
# (Avoid z-ai/glm-4.7-flash here — it's a reasoning model, content comes back
# empty; qwen :free is rate-limited (429) and unreliable.)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# Blog publish target
BLOG_API_URL=http://localhost:7272      # prod: https://api.aifirst.us.com:8444
BOT_API_TOKEN=                          # long random shared secret; MUST equal the backend's BOT_API_TOKEN

# Admin control server (backend -> bot). Optional: unset BOT_CONTROL_TOKEN = control server off.
CONTROL_PORT=8455
BOT_CONTROL_TOKEN=                       # >= 16 chars; MUST equal the backend's BOT_CONTROL_TOKEN

# Storage + schedule
SQLITE_PATH=./data/candidates.db
CRON_SCHEDULE=0 9 * * *
CRON_TZ=Europe/Moscow
MAX_PER_RUN=15

# Optional: comma-separated RSS feed override (RU tech defaults live in src/feeds/parseFeed.ts)
# RSS_FEEDS=https://habr.com/ru/rss/best/daily/?fl=ru,https://3dnews.ru/news/rss

# Optional: CSV keyword filters on title+snippet (case-insensitive), zero LLM cost.
# INCLUDE keeps only matching items; EXCLUDE drops matching items (exclude wins).
# FILTER_INCLUDE=ai,нейросет,gpu,процессор
# FILTER_EXCLUDE=реклама,sponsored,gambling

# Topic relevance filter (AI/tech). Keyword fast-path + one cheap LLM classify.
# RELEVANCE_MODE: off | shadow | on  (default shadow — logs decisions, drops nothing).
# Flip to 'on' only after the shadow logs look right.
RELEVANCE_MODE=shadow
# Keep an item when its LLM relevance score is >= this (0–4).
RELEVANCE_THRESHOLD=2
# Optional model for the classify call; default = the active rewrite model.
# RELEVANCE_MODEL=
# Mirror each relevance decision into the backend audit log (/dashboard/admin/audit-logs).
# Default ON. Set 0/false to silence audit emission without disabling the filter.
# Emission is fire-and-forget and fail-silent — it never blocks a collection run.
RELEVANCE_AUDIT=1
