# Telegram
TELEGRAM_BOT_TOKEN=          # from @BotFather
OWNER_TELEGRAM_ID=           # your numeric Telegram chat id (DM target + auth allowlist)

# Rewrite backend: anthropic (paid) | gemini | glm | deepseek | mock (no LLM)
# glm/deepseek are Chinese, OpenAI-compatible, RU-reachable and cheap/free.
REWRITE_PROVIDER=glm

# Claude — required only when REWRITE_PROVIDER=anthropic
ANTHROPIC_API_KEY=
REWRITE_MODEL=claude-haiku-4-5
# 1 = skip Claude and copy the feed item verbatim (no-credit pipeline testing only).
# Keep 0 in any real environment — mock output is not a real rewrite.
REWRITE_MOCK=0

# Gemini — when REWRITE_PROVIDER=gemini. Key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# GLM (Zhipu Z.ai) — when REWRITE_PROVIDER=glm. glm-4.7-flash is FREE. Key: https://z.ai
GLM_API_KEY=
GLM_MODEL=glm-4.7-flash

# DeepSeek — when REWRITE_PROVIDER=deepseek. V4 Flash ~$0.14/$0.28 per 1M. Key: https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Blog publish target
BLOG_API_URL=http://localhost:7272      # prod: https://api.talalaev.su:8444
BOT_API_TOKEN=                          # long random shared secret; MUST equal the backend's BOT_API_TOKEN

# Admin control server (backend -> bot). Optional: unset BOT_CONTROL_TOKEN = control server off.
CONTROL_PORT=8455
BOT_CONTROL_TOKEN=                       # >= 16 chars; MUST equal the backend's BOT_CONTROL_TOKEN

# Storage + schedule
SQLITE_PATH=./data/candidates.db
CRON_SCHEDULE=0 9 * * *
CRON_TZ=Europe/Moscow
MAX_PER_RUN=15

# Optional: comma-separated RSS feed override (RU tech defaults live in src/feeds.ts)
# RSS_FEEDS=https://habr.com/ru/rss/best/daily/?fl=ru,https://3dnews.ru/news/rss

# Optional: CSV keyword filters on title+snippet (case-insensitive), zero LLM cost.
# INCLUDE keeps only matching items; EXCLUDE drops matching items (exclude wins).
# FILTER_INCLUDE=ai,нейросет,gpu,процессор
# FILTER_EXCLUDE=реклама,sponsored,gambling
