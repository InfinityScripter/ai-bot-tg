# Telegram
TELEGRAM_BOT_TOKEN=          # from @BotFather
OWNER_TELEGRAM_ID=           # your numeric Telegram chat id (DM target + auth allowlist)

# Rewrite backend: anthropic (default, paid) | gemini (free tier) | mock (no LLM)
REWRITE_PROVIDER=gemini

# Claude — required only when REWRITE_PROVIDER=anthropic
ANTHROPIC_API_KEY=
REWRITE_MODEL=claude-haiku-4-5

# Gemini — required when REWRITE_PROVIDER=gemini. Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash

# Blog publish target
BLOG_API_URL=http://localhost:7272      # prod: https://api.talalaev.su:8444
BOT_API_TOKEN=                          # long random shared secret; MUST equal the backend's BOT_API_TOKEN

# Storage + schedule
SQLITE_PATH=./data/candidates.db
CRON_SCHEDULE=0 9 * * *
CRON_TZ=Europe/Moscow
MAX_PER_RUN=15

# Optional: comma-separated RSS feed override (RU tech defaults live in src/feeds.ts)
# RSS_FEEDS=https://habr.com/ru/rss/best/daily/?fl=ru,https://3dnews.ru/news/rss
